<Window x:Class="Przeliterowywacz.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:Przeliterowywacz.Properties"
        Title="{x:Static p:Resources.OptionsCaption}" SizeToContent="WidthAndHeight" ResizeMode="NoResize" Icon="Iconexpo-Speech-Balloon-Grey-Speech-balloon-white-p.ico" UseLayoutRounding="True">
    <Window.Background>
        <RadialGradientBrush>
            <GradientStop Color="#FF099BEA" Offset="0" />
            <GradientStop Color="#FF166ADA" Offset="0.5" />
            <GradientStop Color="#FF623FD2" Offset="1" />
        </RadialGradientBrush>
    </Window.Background>
    <StackPanel Margin="10,5,10,10">
        <GroupBox Header="{x:Static p:Resources.SpeechbankSettings}" Foreground="White">
            <UniformGrid Rows="2" HorizontalAlignment="Stretch" VerticalAlignment="Top">
                <CheckBox Name="CheckBox1" Content="{x:Static p:Resources.EnableSpecialChars}" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="White" Checked="CheckBox1_Checked" Unchecked="CheckBox1_Unchecked"/>
                <CheckBox Name="CheckBox2" Content="{x:Static p:Resources.DeriveFromDefaultSpeechbank}" HorizontalAlignment="Left" Margin="0,2,0,0" VerticalAlignment="Top" Foreground="White" Checked="CheckBox2_Checked" Unchecked="CheckBox2_Unchecked"/>
            </UniformGrid>
        </GroupBox>
        <GroupBox Header="{x:Static p:Resources.SAPI5Settings}" Margin="0,3,0,0" Foreground="White">
            <UniformGrid Columns="2" HorizontalAlignment="Stretch" VerticalAlignment="Top">
                <DockPanel HorizontalAlignment="Stretch" Margin="0,1,0,0" VerticalAlignment="Top">
                    <Label Content="{x:Static p:Resources.Rate}" Foreground="White"/>
                    <TextBox Name="NumberBox1" Width="35" MaxLength="3" TextChanged="NumberBox1_TextChanged"/>
                    <UniformGrid Rows="2" HorizontalAlignment="Left" Width="13" VerticalAlignment="Top">
                        <Button Name="buttonOneMore1" Content="▲" Height="13" FontSize="6" Click="buttonOneMore1_Click"/>
                        <Button Name="buttonOneLess1" Content="▼" Height="13" FontSize="6" Click="buttonOneLess1_Click"/>
                    </UniformGrid>
                </DockPanel>
                <DockPanel HorizontalAlignment="Stretch" Margin="0,1,0,0" VerticalAlignment="Top">
                    <Label Content="{x:Static p:Resources.Volume}" Foreground="White"/>
                    <TextBox Name="NumberBox2" Width="35" MaxLength="3" TextChanged="NumberBox2_TextChanged"/>
                    <UniformGrid Rows="2" HorizontalAlignment="Left" Width="13" VerticalAlignment="Top">
                        <Button Name="buttonOneMore2" Content="▲" Height="13" FontSize="6" Click="buttonOneMore2_Click"/>
                        <Button Name="buttonOneLess2" Content="▼" Height="13" FontSize="6" Click="buttonOneLess2_Click"/>
                    </UniformGrid>
                </DockPanel>
            </UniformGrid>
        </GroupBox>
        <GroupBox Header="{x:Static p:Resources.CommonSettings}" Margin="0,3,0,0" Foreground="White">
            <CheckBox Name="CheckBox3" Content="{x:Static p:Resources.ReadZeroAsOLetter}" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="White" Checked="CheckBox3_Checked" Unchecked="CheckBox3_Unchecked"/>
        </GroupBox>
        <GroupBox Header="{x:Static p:Resources.Use}" Margin="0,3,0,0" Foreground="White">
            <UniformGrid Columns="2" HorizontalAlignment="Stretch" VerticalAlignment="Top">
                <RadioButton Name="RadioButton1" Content="{x:Static p:Resources.Speechbanks}" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="White" Checked="RadioButton1_Checked"/>
                <RadioButton Name="RadioButton2" Content="{x:Static p:Resources.SAPI5Synthesis}" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="White" Checked="RadioButton2_Checked"/>
            </UniformGrid>
        </GroupBox>
        <DockPanel HorizontalAlignment="Stretch" Margin="0,5,0,0" VerticalAlignment="Top">
            <Label Content="{x:Static p:Resources.TextInputColorScheme}" Foreground="White"/>
            <UniformGrid Columns="3" HorizontalAlignment="Stretch" VerticalAlignment="Top">
                <Button Name="StyleButton1" Content="{x:Static p:Resources.Standard}" Background="#7FFFFFC0" Foreground="White" Click="StyleButton1_Click"/>
                <Button Name="StyleButton2" Content="{x:Static p:Resources.BlackAndWhite}" Background="White" Foreground="Black" Click="StyleButton2_Click"/>
                <Button Name="StyleButton3" Content="{x:Static p:Resources.Console}" Background="Black" Foreground="Lime" Click="StyleButton3_Click"/>
            </UniformGrid>
        </DockPanel>
        <DockPanel HorizontalAlignment="Stretch" Margin="0,1,0,0" VerticalAlignment="Top">
            <Label Content="{x:Static p:Resources.Speechbank}" Foreground="White"/>
            <ComboBox Name="ComboBox1" HorizontalAlignment="Stretch" VerticalAlignment="Top" SelectionChanged="ComboBox1_SelectionChanged">
                <ComboBoxItem Content="{x:Static p:Resources.Default}"/>
            </ComboBox>
        </DockPanel>
        <DockPanel HorizontalAlignment="Stretch" Margin="0,1,0,0" VerticalAlignment="Top">
            <Label Content="{x:Static p:Resources.SAPI5Voice}" Foreground="White"/>
            <ComboBox Name="ComboBox3" HorizontalAlignment="Stretch" VerticalAlignment="Top" SelectionChanged="ComboBox3_SelectionChanged"/>
        </DockPanel>
        <DockPanel HorizontalAlignment="Stretch" Margin="0,1,0,0" VerticalAlignment="Top">
            <Label Content="{x:Static p:Resources.Language}" Foreground="White"/>
            <ComboBox Name="ComboBox2" HorizontalAlignment="Stretch" VerticalAlignment="Top" SelectionChanged="ComboBox2_SelectionChanged">
                <WrapPanel>
                    <Image Source="pack://application:,,,/Resources/ca.png" Margin="0,0,5,0"/>
                    <TextBlock>English</TextBlock>
                </WrapPanel>
                <WrapPanel>
                    <Image Source="pack://application:,,,/Resources/pl.png" Margin="0,0,5,0"/>
                    <TextBlock>Polski</TextBlock>
                </WrapPanel>
                <WrapPanel>
                    <Image Source="pack://application:,,,/Resources/de.png" Margin="0,0,5,0"/>
                    <TextBlock>Deutsch</TextBlock>
                </WrapPanel>
            </ComboBox>
        </DockPanel>
        <!--<Button Content="_OK" HorizontalAlignment="Stretch" Margin="0,89,0,11" VerticalAlignment="Top" Width="75" Click="Button_Click"/>-->
        <UniformGrid Columns="2" HorizontalAlignment="Stretch" Margin="0,6,0,0" VerticalAlignment="Top" >
            <Button Name="DockButton1" Content="_OK" Width="140" Click="DockButton1_Click"/>
            <Button Name="DockButton2" Content="{x:Static p:Resources.SaveSettingsButton}" Width="140" Click="DockButton2_Click"/>
        </UniformGrid>
    </StackPanel>
</Window>
