<Window x:Class="Przeliterowywacz.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:Przeliterowywacz.Properties"
        Title="{x:Static p:Resources.AboutCaption}" SizeToContent="WidthAndHeight" ResizeMode="NoResize" Icon="Iconexpo-Speech-Balloon-Grey-Speech-balloon-white-p.ico">
    <Window.Background>
        <RadialGradientBrush>
            <GradientStop Color="#FF099BEA" Offset="0" />
            <GradientStop Color="#FF166ADA" Offset="0.5" />
            <GradientStop Color="#FF623FD2" Offset="1" />
        </RadialGradientBrush>
    </Window.Background>
    <StackPanel>
        <Label Name="Label1" Content="{x:Static p:Resources.AboutContent}" HorizontalAlignment="Center" VerticalAlignment="Top" Foreground="White"/>
        <UniformGrid Columns="2" HorizontalAlignment="Stretch" Margin="0,4,0,10" VerticalAlignment="Top">
            <Button Name="DockButton1" Content="_OK" Width="110" Click="DockButton1_Click"/>
            <Button Name="DockButton2" Content="{x:Static p:Resources.WebsiteButton}" Width="110" Click="DockButton2_Click"/>
        </UniformGrid>
    </StackPanel>
</Window>
